# Copier ce fichier en .env.local et renseigner avec les clés du projet Supabase.
# - Local : valeurs affichées par `supabase status` (API URL + anon/publishable key locale)
# - Cloud  : Project Settings > API  (URL + "publishable" / anon key)
#
# La clé "publishable" (sb_publishable_...) ou anon (eyJ...) va dans VITE_SUPABASE_ANON_KEY.
# Ne JAMAIS mettre la clé service_role ici.

VITE_SUPABASE_URL=https://VOTRE_PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=remplacer_par_la_clef_publishable
